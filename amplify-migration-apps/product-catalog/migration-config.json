{
  "app": {
    "name": "product-catalog",
    "description": "Product catalog with IAM-based authentication, S3 storage with trigger, and inventory management",
    "framework": "react"
  },
  "categories": {
    "api": {
      "type": "GraphQL",
      "schema": "schema.graphql",
      "authModes": ["IAM", "API_KEY", "COGNITO_USER_POOLS"],
      "customQueries": ["checkLowStock"]
    },
    "auth": {
      "signInMethods": ["email"],
      "socialProviders": []
    },
    "storage": {
      "buckets": [
        {
          "name": "productimages",
          "access": ["auth"]
        }
      ],
      "triggers": [
        {
          "name": "S3Trigger",
          "events": ["objectCreated"],
          "function": "S3Trigger"
        }
      ]
    },
    "function": {
      "functions": [
        {
          "name": "lowstockproducts",
          "runtime": "nodejs",
          "template": "hello-world"
        }
      ]
    },
    "hosting": {
      "type": "amplify-console"
    }
  }
}
