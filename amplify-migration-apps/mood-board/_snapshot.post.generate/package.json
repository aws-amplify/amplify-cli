{
  "name": "@amplify-migration-apps/mood-board-app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "installConfig": {
    "hoistingLimits": "workspaces"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "configure": "./configure.sh",
    "sanitize": "tsx ../sanitize.ts",
    "typecheck": "cd _snapshot.post.generate/amplify && npx tsc --noEmit"
  },
  "dependencies": {
    "@aws-amplify/ui-react": "^6.10.1",
    "aws-amplify": "^6.14.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.18.0",
    "@aws-amplify/backend-cli": "^1.8.0",
    "@aws-amplify/backend-data": "^1.6.2",
    "@types/aws-lambda": "^8.10.92",
    "@types/node": "*",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "aws-cdk": "^2",
    "aws-cdk-lib": "^2",
    "ci-info": "^4.3.1",
    "constructs": "^10.0.0",
    "esbuild": "^0.27.0",
    "tsx": "^4.20.6",
    "typescript": "^5.5.3",
    "vite": "^5.4.2"
  }
}
