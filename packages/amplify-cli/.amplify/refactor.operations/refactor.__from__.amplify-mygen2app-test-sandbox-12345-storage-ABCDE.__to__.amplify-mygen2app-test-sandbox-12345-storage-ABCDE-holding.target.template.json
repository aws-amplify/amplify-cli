{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Temporary holding stack for Gen2 migration",
  "Resources": {
    "Gen2S3Bucket": {
      "Type": "AWS::S3::Bucket",
      "Properties": {
        "BucketName": {
          "Fn::Join": [
            "-",
            [
              "my-test-bucket",
              {
                "Ref": "Environment"
              }
            ]
          ]
        }
      }
    },
    "MyOtherGen2S3Bucket": {
      "Type": "AWS::S3::Bucket",
      "Properties": {
        "BucketName": "my-other-s3-bucket-2"
      },
      "DependsOn": [
        "Gen2S3Bucket"
      ]
    }
  },
  "Outputs": {}
}